{
    "name": "low-gravitas-theme",
    "displayName": "Low Gravitas",
    "description": "A VS Code theme with high contrast and low blue light for large areas. Dark and light variants.",
    "version": "2.0.0",
    "publisher": "low-gravitas",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/low-gravitas/low-gravitas-theme"
    },
    "keywords": [
        "Theme",
        "Dark Theme",
        "Light Theme",
        "Low Gravitas",
        "Accessible Theme"
    ],
    "galleryBanner": {
        "color": "#100c00",
        "theme": "dark"
    },
    "engines": {
        "vscode": "^1.63.0"
    },
    "categories": [
        "Themes"
    ],
    "icon": "low-grav.png",
    "contributes": {
        "themes": [
            {
                "label": "Low Gravitas",
                "uiTheme": "vs-dark",
